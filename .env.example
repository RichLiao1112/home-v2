LOGIN_PASSWORD=change-me
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_SESSION_MAX_AGE_SECONDS=43200
SNAPSHOT_MAX_PER_KEY=30
NEXT_PUBLIC_RECYCLE_RETENTION_DAYS=30
UNSPLASH_ACCESS_KEY=
ASSETS_DIR=/app/assets
BUILTIN_MEDIA_DIR=/app/media-builtin

# 和风天气 API（可选，用于天气组件）
# 注册地址：https://dev.qweather.com/
QWEATHER_API_HOST=
QWEATHER_API_KEY=

# MCP 服务认证（可选，用于外部API调用）
# 设置 API Key 后，调用 MCP 服务需要提供此 Key
MCP_API_KEY=

# MCP 服务每日调用限制（默认150次，与天气组件共享配额）
MCP_DAILY_LIMIT=150

